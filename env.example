# ════════════════════════════════════════════════════════
# hackathon-ibm — Environment Configuration
# Copy to .env and fill in the values you need.
# Only ONE provider is required. The system auto-detects.
# ════════════════════════════════════════════════════════

# ── HOW TO SELECT YOUR PROVIDER ──────────────────────────
# Option A: Set SWARM_MODEL with provider prefix
#   SWARM_MODEL=snowflake/openai-gpt-4.1
#   SWARM_MODEL=ollama/deepseek-r1:14b
#   SWARM_MODEL=anthropic/claude-opus-4-5
#   SWARM_MODEL=bedrock/us.amazon.nova-lite-v1:0
#   SWARM_MODEL=openai/gpt-4o
#   SWARM_MODEL=openrouter/anthropic/claude-3.5-sonnet
#   SWARM_MODEL=gemini/gemini-2.0-flash
#   SWARM_MODEL=groq/llama-3.3-70b-versatile
#   SWARM_MODEL=mistral/mistral-large-latest
#
# Option B: Use CLI flags
#   python main.py --provider snowflake --model openai-gpt-4.1
#   python main.py --provider ollama --model deepseek-r1:14b
#
# Option C: Just set the API key — auto-detected:
#   Priority: Snowflake → Anthropic → OpenRouter → OpenAI → Gemini → Groq → Mistral → Ollama

SWARM_MODEL=snowflake/claude-3-5-sonnet

# ════════════════════════════════════════════════════════
# SNOWFLAKE CORTEX
# ════════════════════════════════════════════════════════
SNOWFLAKE_ACCOUNT=youraccountidentifier
SNOWFLAKE_USER=yourusername
SNOWFLAKE_PASSWORD=yourpassword
SNOWFLAKE_WAREHOUSE=yourwarehouse
SNOWFLAKE_DATABASE=yourdatabase
SNOWFLAKE_SCHEMA=schema

SNOWFLAKE_ACCOUNT_ID=SFEDU02.DYB15780

# ════════════════════════════════════════════════════════
# OTHER PROVIDERS (uncomment what you use)
# ════════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
# MISTRAL_API_KEY=...
# GROQ_API_KEY=gsk_...
# COHERE_API_KEY=...
# TOGETHER_API_KEY=...
# HF_TOKEN=hf_...
# CUSTOM_LLM_URL=http://localhost:8000/v1
# GITHUB_TOKEN=ghp_...

# ════════════════════════════════════════════════════════
# OPTIONAL TRACING (DISABLED UNLESS EXPLICITLY CONFIGURED)
# ════════════════════════════════════════════════════════
# To enable OpenTelemetry export, set an OTLP endpoint.
# Example for a local collector:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
